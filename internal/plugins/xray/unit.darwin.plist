<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.shepherd.xray</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/shepherd-xray</string>
        <string>run</string>
        <string>-c</string>
        <string>/etc/shepherd-xray/config.json</string>
    </array>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>
    <key>StandardOutPath</key><string>/var/log/shepherd-xray.out.log</string>
    <key>StandardErrorPath</key><string>/var/log/shepherd-xray.err.log</string>
</dict>
</plist>
